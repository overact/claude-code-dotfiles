{
  "env": {
    "CC_BUSY_THRESHOLD_S": "60"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/project_session_start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'date +%s > \"${XDG_RUNTIME_DIR:-/tmp}/.cc_turn_start\"'",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/notify_local.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/handoff_reminder.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/notify_local.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 $HOME/.claude/statusline.py 2>/dev/null"
  }
}
